{
  "name": "ivid",
  "private": true,
  "version": "0.1.0",
  "description": "ivid video player",
  "author": "unsafezero <unsafezero@gmail.com>",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "bun run build && electron-builder",
    "electron:build:win": "bun run build && electron-builder --win"
  },
  "build": {
    "appId": "com.ivid.app",
    "productName": "ivid",
    "directories": {
      "output": "dist-electron"
    },
    "fileAssociations": [
      {
        "ext": "mp4",
        "name": "Video",
        "role": "Viewer"
      },
      {
        "ext": "mkv",
        "name": "Video",
        "role": "Viewer"
      },
      {
        "ext": "webm",
        "name": "Video",
        "role": "Viewer"
      },
      {
        "ext": "avi",
        "name": "Video",
        "role": "Viewer"
      },
      {
        "ext": "mov",
        "name": "Video",
        "role": "Viewer"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
